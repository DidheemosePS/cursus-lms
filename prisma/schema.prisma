generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  instructor
  learner
}

enum UserStatus {
  pending_invite
  active
  inactive
}

enum CourseStatus {
  draft
  active
  archived
}

enum EnrollmentStatus {
  enrolled
  unenrolled
}

enum SubmissionStatus {
  submitted
  reviewed
}

enum ConversationType {
  direct
  group
}

enum NotificationType {
  new_submission
  feedback_given
  new_message
  enrollment_invite
}

model Organization {
  id        String   @id @default(uuid(7))
  name      String
  slug      String   @unique
  users     User[]
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String       @id @default(uuid(7))
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name         String
  email        String     @unique
  passwordHash String
  salt         String
  role         UserRole
  status       UserStatus @default(pending_invite)

  enrollments Enrollment[]
  instructedCourses CourseInstructor[]
  submissions Submission[]
  messages    Message[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationMembers ConversationMember[]
  feedbacks        Feedback[]
  recentActivities RecentActivities[]
}

model Course {
  id             String       @id @default(uuid(7))
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title       String
  description String
  code        String
  coverImageUrl String
  status      CourseStatus @default(draft)

  modules       Module[]
  instructors   CourseInstructor[]
  enrollments   Enrollment[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id       String @id @default(uuid(7))
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  title       String
  description String
  position    Int
  startDate   DateTime
  dueDate     DateTime

  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CourseInstructor {
  id            String @id @default(uuid(7))
  courseId      String
  instructorId  String

  course      Course @relation(fields: [courseId], references: [id])
  instructor  User   @relation(fields: [instructorId], references: [id])

  createdAt DateTime @default(now())

  @@unique([courseId, instructorId])
}

model Enrollment {
  id        String @id @default(uuid(7))
  courseId  String
  learnerId String

  course  Course @relation(fields: [courseId], references: [id])
  learner User   @relation(fields: [learnerId], references: [id])

  status       EnrollmentStatus
  enrolledAt   DateTime?
  inviteSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, learnerId])
}

model Submission {
  id        String @id @default(uuid(7))
  moduleId  String
  learnerId String

  module  Module @relation(fields: [moduleId], references: [id])
  learner User   @relation(fields: [learnerId], references: [id])

  attemptNumber Int
  fileUrl       String
  fileName      String
  fileSize      Int

  submittedAt DateTime
  isLate      Boolean
  status      SubmissionStatus @default(submitted)

  feedback Feedback?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, learnerId, attemptNumber])
}

model Feedback {
  id            String @id @default(uuid(7))
  submissionId  String @unique
  instructorId  String

  submission Submission @relation(fields: [submissionId], references: [id])
  instructor User       @relation(fields: [instructorId], references: [id])

  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id       String           @id @default(uuid(7))
  courseId String
  type     ConversationType

  course   Course               @relation(fields: [courseId], references: [id])
  members  ConversationMember[]
  messages Message[]

  createdAt DateTime @default(now())
}

model ConversationMember {
  id             String @id @default(uuid(7))
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String @id @default(uuid(7))
  conversationId String
  senderId       String

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  content String

  createdAt DateTime @default(now())
}

model Notification {
  id          String           @id @default(uuid(7))
  userId      String
  type        NotificationType
  referenceId String
  isRead      Boolean          @default(false)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

enum Action {
  created
  updated
  delete
  modified
  assigned
}

model RecentActivities {
  id             String @id @default(uuid(7))
  userId         String
  organizationId String
  action         Action
  target         String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
